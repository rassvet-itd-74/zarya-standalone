# RPC endpoint for the deployed Zarya.sol contract.
# Copy this file to .env and fill in the values before running or building.
VITE_RPC_URL=

# GitHub personal access token used by `npm run publish` (Electron Forge publisher-github).
# Required scopes: repo (for private repos) or public_repo (for public repos).
# Generate at: https://github.com/settings/tokens
# In CI, set this as a repository secret named GITHUB_TOKEN.
GITHUB_TOKEN=
